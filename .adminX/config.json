{
  "media": {
    "root": "public/images",
    "public": "public"
  },
  "content": {
    "root": "src/content"
  },
  "themeConfig": [
    "src/config"
  ],
  "arrangement": {
    "src/content/homepage/_index.md": {
      "Homepage": {
        "weight": 0
      }
    },
    "Blog": {
      "type": "heading",
      "weight": 1
    },
    "src/content/blog/_index.md": {
      "Blog Index": {
        "weight": 2
      }
    },
    "src/content/blog": {
      "Blogs": {
        "weight": 3,
        "include": "",
        "exclude": "_index.md"
      }
    },
    "Author": {
      "type": "heading",
      "weight": 4
    },
    "src/content/authors/_index.md": {
      "Author Index": {
        "weight": 5
      }
    },
    "src/content/authors": {
      "Posts": {
        "weight": 6,
        "include": "",
        "exclude": "_index.md"
      }
    }
  }
}