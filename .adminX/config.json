{
  "media": {
    "root": "public/images",
    "public": "public"
  },
  "content": {
    "root": "src/content"
  },
  "themeConfig": [
    "src/config"
  ],
  "arrangement": {
    "Blog": {
      "type": "heading",
      "weight": 0
    },
