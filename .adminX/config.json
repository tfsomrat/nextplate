        "weight": 1
      }
    },
    "src/content/blog": {
      "Blogs": {
        "weight": 2,
        "include": "",
        "exclude": "_index.md"
      }
    },
    "Author": {
      "type": "heading",
      "weight": 3
    },
    "src/content/authors/_index.md": {
